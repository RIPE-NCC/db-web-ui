{
    "name": "db-web-ui",
    "version": "0.0.0",
    "scripts": {
        "clean": "rm -rf node_modules",
        "ng": "ng",
        "start": "ng run frontend:serve:local --ssl true",
        "start-mock": "ng run frontend:serve-mock:local",
        "build": "ng build --configuration=production",
        "build-dev": "ng build --configuration=local",
        "test": "ng test --configuration=local --watch=false --code-coverage --include=../test/**/*.spec.ts",
        "test-remote": "ng test --configuration=remote --watch=false --include=../test/**/*.spec.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "ng lint",
        "prepare": "cd .. && husky install frontend/.husky",
        "lint-staged": "lint-staged",
        "cypress:open": "cypress open",
        "cypress:chrome": "ng run frontend:cypress --browser chrome",
        "cypress:firefox": "ng run frontend:cypress --browser firefox",
        "supportedBrowsers": "echo \"export default $(browserslist-useragent-regexp --allowHigherVersions);\" > src/assets/supportedBrowsers.js",
        "blockedBrowsers": "echo \"window.blockedBrowsers = $(browserslist-useragent-regexp \"firefox < 126 or safari < 18 or opera < 112 or chrome < 126 or dead\");\" > src/assets/blockedBrowsers.js",
        "postinstall": "npm run supportedBrowsers && npm run blockedBrowsers"
    },
    "private": true,
    "devDependencies": {
        "@angular-builders/custom-esbuild": "21.0.3",
        "@angular-eslint/builder": "21.3.1",
        "@angular-eslint/eslint-plugin": "21.3.1",
        "@angular-eslint/eslint-plugin-template": "21.3.1",
        "@angular-eslint/schematics": "21.3.1",
        "@angular-eslint/template-parser": "21.3.1",
        "@angular/build": "21.2.3",
        "@angular/cli": "21.2.3",
        "@angular/compiler-cli": "21.2.5",
        "@angular/language-service": "21.2.5",
        "@babel/core": "7.26.10",
        "@babel/preset-env": "7.26.9",
        "@babel/runtime": "7.26.10",
        "@types/diff-match-patch": "1.0.36",
        "@types/jasmine": "4.0.3",
        "@types/jasminewd2": "2.0.10",
        "@types/lodash": "4.14.195",
        "@types/node": "22.15.21",
        "@types/sanitize-html": "2.6.2",
        "@typescript-eslint/eslint-plugin": "8.57.1",
        "@typescript-eslint/parser": "8.57.1",
        "connect-prism": "1.0.21",
        "cypress": "14.5.4",
        "diff-package-lock": "0.1.33",
        "eslint": "9.29.0",
        "eslint-config-prettier": "9.1.2",
        "husky": "8.0.3",
        "jasmine-core": "4.0.1",
        "jasmine-spec-reporter": "7.0.0",
        "karma": "6.4.4",
        "karma-chrome-launcher": "3.2.0",
        "karma-coverage-istanbul-reporter": "3.0.3",
        "karma-jasmine": "5.1.0",
        "karma-jasmine-html-reporter": "2.1.0",
        "karma-spec-reporter": "0.0.36",
        "lint-staged": "12.4.3",
        "prettier": "2.8.8",
        "prettier-plugin-organize-imports": "3.2.2",
        "ts-node": "10.7.0",
        "typescript": "5.9.3"
    },
    "engines": {
        "node": ">=22.21.1",
        "npm": ">=11.12.0"
    },
    "dependencies": {
        "@angular/animations": "21.2.5",
        "@angular/cdk": "21.2.3",
        "@angular/common": "21.2.5",
        "@angular/compiler": "21.2.5",
        "@angular/core": "21.2.5",
        "@angular/forms": "21.2.5",
        "@angular/localize": "21.2.5",
        "@angular/material": "21.2.3",
        "@angular/material-moment-adapter": "21.2.3",
        "@angular/platform-browser": "21.2.5",
        "@angular/platform-browser-dynamic": "21.2.5",
        "@angular/router": "21.2.5",
        "@cypress/schematic": "3.0.0",
        "@fortawesome/fontawesome-pro": "7.1.0",
        "@lir-portal/web-components": "1.0.1",
        "@ng-bootstrap/ng-bootstrap": "20.0.0",
        "@ng-select/ng-select": "21.5.2",
        "@ngx-loading-bar/core": "6.0.2",
        "@ngx-loading-bar/http-client": "6.0.2",
        "@technical-design/ripe-app-webcomponents": "4.3.0",
        "@typeform/embed": "5.3.1",
        "@types/crypto-js": "4.2.2",
        "angulartics": "1.6.0",
        "angulartics-piwik": "1.0.6",
        "bootstrap": "5.2.3",
        "browserslist-useragent-regexp": "4.1.0",
        "classlist": "2.0.0",
        "cookie-parser": "1.4.7",
        "crypto-js": "4.2.0",
        "diff-match-patch": "1.0.5",
        "ip-address": "8.1.0",
        "lodash": "4.18.1",
        "moment": "2.30.1",
        "moment-timezone": "0.6.0",
        "ngx-cookie-service": "21.3.1",
        "rxjs": "7.5.5",
        "sanitize-html": "2.17.2",
        "tslib": "2.3.1",
        "whatwg-fetch": "3.6.2",
        "zone.js": "0.15.1"
    },
    "overrides": {
        "minimist": "1.2.8",
        "uri-js": "npm:uri-js-replace",
        "tar": "7.5.11",
        "undici": "7.24.0",
        "rollup": "4.59.0",
        "picomatch": "4.0.4"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    }
}
